{
  "name": "vue-layerx",
  "version": "1.0.0-beta.1",
  "description": "让弹窗组件通过命令方式调用",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:coverage:integration": "vitest run --coverage tests/integration",
    "prepublishOnly": "pnpm test && pnpm build",
    "playground": "pnpm build && pnpm --filter playground dev",
    "playground:build": "pnpm build && pnpm --filter playground build",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "site:build": "pnpm docs:build && pnpm playground:build && rm -rf docs/.vitepress/dist/playground && cp -R playground/dist docs/.vitepress/dist/playground"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xuyimingwork/vue-layerx.git"
  },
  "homepage": "https://xuyimingwork.github.io/vue-layerx/",
  "bugs": {
    "url": "https://github.com/xuyimingwork/vue-layerx/issues"
  },
  "keywords": [
    "vue",
    "vue3",
    "dialog",
    "modal",
    "layer",
    "composable"
  ],
  "license": "MIT",
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.4",
    "@vue/test-utils": "^2.4.6",
    "element-plus": "^2.11.4",
    "jsdom": "^26.1.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitepress": "^1.6.3",
    "vitest": "^3.2.4",
    "vue": "^3.5.16"
  }
}
